# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mad_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET="your-secure-secret-key-min-32-characters-recommended"
JWT_REFRESH_SECRET="your-secure-refresh-key-min-32-characters-recommended"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# File Upload
MAX_UPLOAD_SIZE="50mb"
UPLOAD_DIR="./uploads"

# Logging
LOG_LEVEL="info"

# n8n Configuration (Optional)
N8N_URL="http://localhost:5678"
N8N_API_KEY="your-n8n-api-key"

# Concert Scraping APIs (Required for concert data)
# Note: Social media APIs (Spotify, Instagram, YouTube) are handled by n8n workflows
SETLISTFM_API_KEY="your-setlistfm-api-key"
# Also accepted for compatibility with ml_engine/.env:
SETLIST_API_KEY="your-setlistfm-api-key"
SETLISTFM_MAX_PAGES_PER_YEAR="10"
BANDSINTOWN_API_KEY="your-bandsintown-api-key"
PAYTM_INSIDER_API_KEY="your-paytm-insider-api-key"
SONGKICK_API_KEY="your-songkick-api-key"
EVENTBRITE_API_KEY="your-eventbrite-api-key"

# Venue research
VENUE_RESEARCH_WIKIDATA_ENABLED="true"
WIKIDATA_USER_AGENT="MAD-Dashboard/1.0 (your-email@example.com)"

# Concert revenue defaults
DEFAULT_CONCERT_CURRENCY="INR"

# Search APIs (Optional - for web search fallback)
GOOGLE_SEARCH_API_KEY="your-google-search-api-key"
GOOGLE_SEARCH_CX="your-google-search-cx"
BING_SEARCH_API_KEY="your-bing-search-api-key"

# Python path for ML model
PYTHON_PATH=python

# Email Configuration (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
