generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artist {
  id                      String                @id @default(dbgenerated("gen_random_uuid()"))
  artistName              String                @unique
  displayName             String?
  age                     Int?
  gender                  String?
  genre                   String?
  nationality             String?
  bio                     String?
  photoUrl                String?
  wikiUrl                 String?
  active                  Boolean               @default(true)
  instagramFollowers      BigInt?
  facebookFollowers       BigInt?
  twitterFollowers        BigInt?
  spotifyMonthlyListeners BigInt?
  youtubeSubscribers      BigInt?
  popularity              Decimal?              @db.Decimal(5, 2)
  imageUrl                String?
  spotifyFollowers        BigInt?
  topCity1                String?
  topCity2                String?
  topCity3                String?
  topCity4                String?
  topCity5                String?
  lastUpdated             DateTime?
  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt
  genres                  ArtistGenre[]
  audienceDemographics    AudienceDemographic[]
  concerts                Concert[]
  featureSnapshots        FeatureSnapshot[]
  platformMetrics         PlatformMetric[]

  @@index([artistName])
  @@index([active])
  @@map("artists")
}

model Genre {
  id         Int           @id @default(autoincrement())
  name       String        @unique
  created_at DateTime      @default(now())
  artists    ArtistGenre[]

  @@map("genres")
}

model ArtistGenre {
  artistId String
  genreId  Int
  id       Int    @id @default(autoincrement())
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre    Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@unique([artistId, genreId])
  @@map("artist_genres")
}

model PlatformMetric {
  id          String       @id @default(dbgenerated("gen_random_uuid()"))
  artistId    String
  platform    Platform
  metricDate  DateTime     @db.Date
  followers   BigInt       @default(0)
  likes       BigInt       @default(0)
  shares      BigInt       @default(0)
  comments    BigInt       @default(0)
  streams     BigInt       @default(0)
  rogDaily    Decimal?     @db.Decimal(8, 4)
  rogWeekly   Decimal?     @db.Decimal(8, 4)
  rogMonthly  Decimal?     @db.Decimal(8, 4)
  source      MetricSource @default(API)
  rawSnapshot Json?
  created_at  DateTime     @default(now())
  artist      Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, platform, metricDate])
  @@index([artistId, platform, metricDate])
  @@index([metricDate])
  @@map("platform_metrics")
}

model Venue {
  id             String   @id @default(cuid())
  name           String
  city           String
  state          String?
  country        String
  address        String?
  latitude       Decimal? @db.Decimal(9, 6)
  longitude      Decimal? @db.Decimal(9, 6)
  capacityMin    Int?
  capacityMax    Int?
  avgCapacity    Int?
  ticketPriceMin Decimal? @db.Decimal(10, 2)
  ticketPriceMax Decimal? @db.Decimal(10, 2)
  avgTicketPrice Decimal? @db.Decimal(10, 2)
  venueType      String?
  verified       Boolean  @default(false)
  source         String?
  sourceUrl      String?
  lastUpdated    DateTime @default(now())
  created_at     DateTime @default(now())

  @@unique([name, city, country])
  @@index([city, country])
  @@map("venues")
}

model Concert {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()"))
  artistId             String
  concertDate          DateTime                  @db.Date
  city                 String
  state                String?
  country              String
  latitude             Decimal?                  @db.Decimal(9, 6)
  longitude            Decimal?                  @db.Decimal(9, 6)
  venueName            String?
  capacity             Int?
  ticketsSold          Int                       @default(0)
  avgTicketPrice       Decimal?                  @db.Decimal(10, 2)
  totalRevenue         Decimal?                  @db.Decimal(14, 2)
  currency             String                    @default("INR")
  notes                String?
  created_at           DateTime                  @default(now())
  artistName           String?
  researchNotes        String?
  source               String?
  sourceUrl            String?
  verificationStatus   ConcertVerificationStatus @default(PENDING)
  verifiedAt           DateTime?
  verifiedBy           String?
  ticketPriceVip       Decimal?                  @db.Decimal(10, 2)
  ticketPriceTier1     Decimal?                  @db.Decimal(10, 2)
  ticketPriceTier2     Decimal?                  @db.Decimal(10, 2)
  ticketPriceTier3     Decimal?                  @db.Decimal(10, 2)
  ticketPriceMin       Decimal?                  @db.Decimal(10, 2)
  ticketPriceMax       Decimal?                  @db.Decimal(10, 2)
  artistCityPopularity Decimal?                  @db.Decimal(5, 2)
  demandScore          Decimal?                  @db.Decimal(5, 2)
  audienceDemographics AudienceDemographic[]
  canonicalEvents      CanonicalEvent[]
  artist               Artist                    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  featureSnapshots     FeatureSnapshot[]
  predictionOutputs    PredictionOutput[]
  validationLogs       ValidationLog[]

  @@index([artistId, concertDate])
  @@index([city])
  @@index([country])
  @@index([verificationStatus])
  @@index([concertDate])
  @@index([source])
  @@index([sourceUrl])
  @@map("concerts")
}

model AudienceDemographic {
  id             String               @id @default(cuid())
  artistId       String?
  concertId      String?
  dimension      DemographicDimension
  dimensionValue String               @db.VarChar(100)
  percentage     Decimal?             @db.Decimal(5, 2)
  absoluteCount  Int?
  sourcePlatform String?              @db.VarChar(100)
  metricDate     DateTime             @db.Date
  created_at     DateTime             @default(now())
  artist         Artist?              @relation(fields: [artistId], references: [id])
  concert        Concert?             @relation(fields: [concertId], references: [id])

  @@index([artistId])
  @@index([concertId])
  @@index([dimension])
  @@map("audience_demographics")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(VIEWER)
  active        Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model IngestionJob {
  id           String    @id @default(cuid())
  jobType      JobType
  status       JobStatus @default(PENDING)
  fileName     String?
  rowCount     Int       @default(0)
  errorMessage String?
  duration     Int?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@map("ingestion_jobs")
}

model ConcertResearchJob {
  id             String    @id @default(cuid())
  concertId      String
  status         JobStatus @default(PENDING)
  sourcesChecked Json?
  findings       Json?
  confidence     Decimal?  @db.Decimal(3, 2)
  errorMessage   String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([concertId])
  @@index([status])
  @@map("concert_research_jobs")
}

model CanonicalEvent {
  id                    String                 @id @default(cuid())
  artistName            String
  normalizedArtistName  String
  eventName             String?
  venueName             String
  normalizedVenueName   String
  city                  String
  normalizedCity        String
  country               String
  eventDate             DateTime               @db.Date
  sourcePlatform        String
  sourceUrl             String?
  ticketPriceRange      Json?
  confidenceScore       Decimal                @default(0) @db.Decimal(5, 4)
  fraudRiskScore        Decimal?               @db.Decimal(5, 4)
  validationStatus      EventValidationStatus  @default(PENDING)
  canonicalKey          String                 @unique
  embedding             Json?
  rawPayload            Json?
  concertId             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  concert               Concert?               @relation(fields: [concertId], references: [id])
  duplicateGroupMembers DuplicateGroupMember[]
  duplicateGroups       DuplicateGroup[]
  featureSnapshots      FeatureSnapshot[]
  predictionOutputs     PredictionOutput[]
  sourceReferences      SourceEventReference[]
  validationLogs        ValidationLog[]

  @@index([normalizedArtistName, eventDate])
  @@index([validationStatus])
  @@index([sourcePlatform])
  @@index([normalizedVenueName, normalizedCity, eventDate], map: "canonical_events_normalizedVenueName_normalizedCity_eventDate_i")
  @@map("canonical_events")
}

model SourceEventReference {
  id               String         @id @default(cuid())
  canonicalEventId String
  sourcePlatform   String
  sourceEventId    String?
  sourceUrl        String?
  sourceEventKey   String         @unique
  rawPayload       Json?
  confidenceScore  Decimal        @default(0) @db.Decimal(5, 4)
  firstSeenAt      DateTime       @default(now())
  lastSeenAt       DateTime       @updatedAt
  canonicalEvent   CanonicalEvent @relation(fields: [canonicalEventId], references: [id], onDelete: Cascade)

  @@index([canonicalEventId])
  @@index([sourcePlatform])
  @@map("source_event_references")
}

model DuplicateGroup {
  id               String                 @id @default(cuid())
  canonicalEventId String?
  status           DuplicateGroupStatus   @default(OPEN)
  similarityScore  Decimal?               @db.Decimal(5, 4)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  members          DuplicateGroupMember[]
  canonicalEvent   CanonicalEvent?        @relation(fields: [canonicalEventId], references: [id])

  @@index([canonicalEventId])
  @@index([status])
  @@map("duplicate_groups")
}

model DuplicateGroupMember {
  id               String              @id @default(cuid())
  groupId          String
  canonicalEventId String
  role             DuplicateMemberRole @default(CANDIDATE)
  similarityScore  Decimal             @default(0) @db.Decimal(5, 4)
  reasons          Json?
  createdAt        DateTime            @default(now())
  canonicalEvent   CanonicalEvent      @relation(fields: [canonicalEventId], references: [id], onDelete: Cascade)
  group            DuplicateGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, canonicalEventId])
  @@index([canonicalEventId])
  @@map("duplicate_group_members")
}

model ValidationLog {
  id                String                @id @default(cuid())
  canonicalEventId  String?
  concertId         String?
  sourcePlatform    String?
  confidenceScore   Decimal               @db.Decimal(5, 4)
  fraudRiskScore    Decimal               @db.Decimal(5, 4)
  validationStatus  EventValidationStatus
  validationReasons Json
  ruleScores        Json?
  mlSignals         Json?
  createdAt         DateTime              @default(now())
  canonicalEvent    CanonicalEvent?       @relation(fields: [canonicalEventId], references: [id])
  concert           Concert?              @relation(fields: [concertId], references: [id])

  @@index([canonicalEventId])
  @@index([concertId])
  @@index([validationStatus])
  @@map("validation_logs")
}

model PredictionOutput {
  id                 String          @id @default(cuid())
  canonicalEventId   String?
  concertId          String?
  modelVersion       String
  input              Json
  features           Json
  expectedRevenue    Decimal         @db.Decimal(14, 2)
  expectedAttendance Int
  selloutProbability Decimal         @db.Decimal(5, 4)
  demandScore        Decimal         @db.Decimal(5, 2)
  createdAt          DateTime        @default(now())
  canonicalEvent     CanonicalEvent? @relation(fields: [canonicalEventId], references: [id])
  concert            Concert?        @relation(fields: [concertId], references: [id])

  @@index([canonicalEventId])
  @@index([concertId])
  @@index([modelVersion])
  @@map("prediction_outputs")
}

model FeatureSnapshot {
  id                String          @id @default(cuid())
  canonicalEventId  String?
  artistId          String?
  concertId         String?
  featureSetVersion String
  features          Json
  createdAt         DateTime        @default(now())
  artist            Artist?         @relation(fields: [artistId], references: [id])
  canonicalEvent    CanonicalEvent? @relation(fields: [canonicalEventId], references: [id])
  concert           Concert?        @relation(fields: [concertId], references: [id])

  @@index([canonicalEventId])
  @@index([artistId])
  @@index([concertId])
  @@index([featureSetVersion])
  @@map("feature_snapshots")
}

model PredictionTrainingData {
  id               String   @id @default(cuid())
  concertId        String
  features         Json
  actualRevenue    Decimal? @db.Decimal(14, 2)
  predictedRevenue Decimal? @db.Decimal(14, 2)
  accuracy         Decimal? @db.Decimal(5, 2)
  modelVersion     String
  createdAt        DateTime @default(now())

  @@index([modelVersion])
  @@map("prediction_training_data")
}

model PredictionModel {
  id              String    @id @default(cuid())
  name            String
  version         String    @unique
  modelType       String
  accuracy        Decimal   @db.Decimal(5, 2)
  features        Json
  hyperparameters Json?
  filePath        String
  isActive        Boolean   @default(false)
  trainedAt       DateTime  @default(now())
  deployedAt      DateTime?

  @@index([isActive])
  @@map("prediction_models")
}

enum JobType {
  EXCEL_IMPORT
  PLATFORM_SYNC
  CONCERT_RESEARCH
  CONCERT_SCRAPE
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  YOUTUBE
  SPOTIFY
  APPLE_MUSIC
  REDDIT
  QUORA
}

enum MetricSource {
  API
  EXCEL_IMPORT
}

enum DemographicDimension {
  AGE_GROUP
  GENDER
  GEOGRAPHY
  GENRE
}

enum UserRole {
  ADMIN
  VIEWER
}

enum ConcertVerificationStatus {
  PENDING
  RESEARCHING
  VERIFIED
  REJECTED
}

enum EventValidationStatus {
  PENDING
  VALIDATED
  REJECTED
  REVIEW_REQUIRED
  DUPLICATE
}

enum DuplicateGroupStatus {
  OPEN
  MERGED
  DISMISSED
}

enum DuplicateMemberRole {
  CANONICAL
  DUPLICATE
  CANDIDATE
}
