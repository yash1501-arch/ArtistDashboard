      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst rawName = item['Artist names'] || item['Artist Name'] || item['name'] || Object.values(item)[0] || '';\nconst cleanName = rawName.replace(/\\s*\\((?:band|rapper|singer|artist|musician|duo|group|dj)\\)/gi, '').trim();\nconst displayName = rawName.trim();\nconst wikiName = cleanName.replace(/ /g, '_');\nconst twitterHandle = cleanName.replace(/\\s+/g, '');\nreturn [{ json: { artistName: cleanName, displayName, wikiName, twitterHandle } }];"
      },
