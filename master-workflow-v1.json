    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst extract = data.extract || '';\nconst description = data.description || '';\nlet age = null, gender = null, genre = null, nationality = null;\n\nconst birthYearPatterns = [/born(?:[^(\\d]*)(\\d{4})/i, /\\((\\d{4})[-–]/];\nfor (const pat of birthYearPatterns) {\n  const m = extract.match(pat);\n  if (m) { const yr = parseInt(m[1]); if (yr > 1940 && yr < 2015) { age = new Date().getFullYear() - yr; break; } }\n}\nconst directAge = extract.match(/(\\d{2,3})(?:\\s*-year-old|\\s*years\\s*old)/i);\nif (!age && directAge) age = parseInt(directAge[1]);\n\nconst fem = (extract.match(/\\b(she|her|hers|actress|female)\\b/gi) || []).length;\nconst mal = (extract.match(/\\b(he|him|his|male)\\b/gi) || []).length;\nif (fem > mal && fem >= 2) gender = 'Female';\nelse if (mal > fem && mal >= 2) gender = 'Male';\n\nconst GENRES = ['Bollywood','Punjabi','Ghazal','Classical','Sufi','Devotional','Bhangra','Playback','Pop','Rock','Hip-hop','R&B','Jazz','Folk','Soul','Indie','Electronic','Rap','Trap'];\nfor (const g of GENRES) {\n  if (new RegExp('\\\\b' + g + '\\\\b', 'i').test(extract)) { genre = g; break; }\n}\n\nconst NATS = ['Indian','Pakistani','Bangladeshi','Sri Lankan','American','British','Canadian','Australian'];\nnationality = 'Indian';\nfor (const n of NATS) {\n  if (new RegExp('\\\\b' + n + '\\\\b', 'i').test(extract + ' ' + description)) { nationality = n; break; }\n}\n\nconst wikiUrl = data.content_urls?.desktop?.page || null;\nreturn [{ json: { age, gender, genre, nationality, wikiUrl } }];"
      },
