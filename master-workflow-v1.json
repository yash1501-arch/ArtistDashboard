    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\n\nlet facebookUrl = null;\nlet facebookFollowers = null;\n\ntry {\n  // The /page/details endpoint returns data directly or nested\n  const page = data.data || data.page || data.result || data;\n\n  // Get URL — prefer vanity/username URL\n  facebookUrl =\n    page.profile_url ||\n    page.url         ||\n    page.link        ||\n    null;\n\n  // Get followers — try every known field name\n  const raw =\n    page.followers       ||\n    page.followers_count ||\n    page.fan_count       ||\n    page.fans            ||\n    page.likes           ||\n    page.likesCount      ||\n    null;\n\n  // Convert \"29M\" / \"1.2M\" / \"29,000,000\" strings to integer\n  if (raw !== null) {\n    const s = String(raw).replace(/,/g, '').trim();\n    if (/M$/i.test(s)) {\n      facebookFollowers = Math.round(parseFloat(s) * 1_000_000);\n    } else if (/K$/i.test(s)) {\n      facebookFollowers = Math.round(parseFloat(s) * 1_000);\n    } else {\n      facebookFollowers = parseInt(s) || null;\n    }\n  }\n\n} catch(e) {}\n\nreturn [{ json: { facebookUrl, facebookFollowers } }];"
      },
