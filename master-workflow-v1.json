    {
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst artistCtx = $('Extract & Clean Artist Name').item?.json || {};\nconst artistName  = artistCtx.artistName  || d.artistName  || 'Unknown';\nconst displayName = artistCtx.displayName || artistName;\nreturn [{\n  json: {\n    artistName,\n    displayName,\n    age:                     d.age ?? null,\n    gender:                  d.gender ?? null,\n    genre:                   d.genre ?? null,\n    nationality:             d.nationality ?? null,\n    wikiUrl:                 d.wikiUrl ?? null,\n    instagramUrl:            d.instagramUrl ?? null,\n    instagramFollowers:      d.instagramFollowers ?? null,\n    facebookUrl:             d.facebookUrl ?? null,\n    facebookFollowers:       d.facebookFollowers ?? null,\n    twitterUrl:              d.twitterUrl ?? null,\n    twitterFollowers:        d.twitterFollowers ?? null,\n    spotifyUrl:              d.spotifyUrl ?? null,\n    spotifyMonthlyListeners: d.spotifyMonthlyListeners ?? null,\n    youtubeUrl:              d.youtubeUrl ?? null,\n    youtubeSubscribers:      d.youtubeSubscribers ?? null,\n    appleMusicUrl:           d.appleMusicUrl ?? null,\n    appleMusicListeners:     d.appleMusicListeners ?? null,\n    lastUpdated:             new Date().toISOString()\n  }\n}];"
      },
      "id": "0bb76ea4-97bb-4682-a8af-ba7a4e3cb101",
      "name": "Finalize Merged Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4608,
        1376
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst esc = v => v ? String(v).replace(/'/g, \"''\") : null;\nconst str = v => (v !== null && v !== undefined) ? `'${esc(v)}'` : 'NULL';\nconst num = v => (v !== null && v !== undefined && !isNaN(parseInt(v))) ? parseInt(v) : 'NULL';\n\nconst query = `\nINSERT INTO artists (\n  \"artistName\", \"displayName\", age, gender, genre, nationality, \"wikiUrl\",\n  \"instagramUrl\",  \"instagramFollowers\",\n  \"facebookUrl\",   \"facebookFollowers\",\n  \"twitterUrl\",    \"twitterFollowers\",\n  \"spotifyUrl\",    \"spotifyMonthlyListeners\",\n  \"youtubeUrl\",    \"youtubeSubscribers\",\n  \"appleMusicUrl\", \"appleMusicListeners\",\n  \"lastUpdated\"\n) VALUES (\n  ${str(d.artistName)}, ${str(d.displayName)}, ${num(d.age)}, ${str(d.gender)}, ${str(d.genre)}, ${str(d.nationality)}, ${str(d.wikiUrl)},\n  ${str(d.instagramUrl)},  ${num(d.instagramFollowers)},\n  ${str(d.facebookUrl)},   ${num(d.facebookFollowers)},\n  ${str(d.twitterUrl)},    ${num(d.twitterFollowers)},\n  ${str(d.spotifyUrl)},    ${num(d.spotifyMonthlyListeners)},\n  ${str(d.youtubeUrl)},    ${num(d.youtubeSubscribers)},\n  ${str(d.appleMusicUrl)}, ${num(d.appleMusicListeners)},\n  NOW()\n)\nON CONFLICT (\"artistName\") DO UPDATE SET\n  \"displayName\"            = EXCLUDED.\"displayName\",\n  age                      = EXCLUDED.age,\n  gender                   = EXCLUDED.gender,\n  genre                    = EXCLUDED.genre,\n  nationality              = EXCLUDED.nationality,\n  \"wikiUrl\"                = EXCLUDED.\"wikiUrl\",\n  \"instagramUrl\"           = EXCLUDED.\"instagramUrl\",\n  \"instagramFollowers\"     = EXCLUDED.\"instagramFollowers\",\n  \"facebookUrl\"            = EXCLUDED.\"facebookUrl\",\n  \"facebookFollowers\"      = EXCLUDED.\"facebookFollowers\",\n  \"twitterUrl\"             = EXCLUDED.\"twitterUrl\",\n  \"twitterFollowers\"       = EXCLUDED.\"twitterFollowers\",\n  \"spotifyUrl\"             = EXCLUDED.\"spotifyUrl\",\n  \"spotifyMonthlyListeners\" = EXCLUDED.\"spotifyMonthlyListeners\",\n  \"youtubeUrl\"             = EXCLUDED.\"youtubeUrl\",\n  \"youtubeSubscribers\"     = EXCLUDED.\"youtubeSubscribers\",\n  \"appleMusicUrl\"          = EXCLUDED.\"appleMusicUrl\",\n  \"appleMusicListeners\"    = EXCLUDED.\"appleMusicListeners\",\n  \"lastUpdated\"            = NOW()\n`.trim();\n\nreturn [{ json: { ...d, sqlQuery: query } }];"
      },
