    {
      "parameters": {
        "jsCode": "const stats = $json.items[0].statistics;\n\nconst subs = Number(stats.subscriberCount);\nconst views = Number(stats.viewCount);\nconst videos = Number(stats.videoCount);\n\n// Avg views per video\nconst avgViews = views / videos;\n\n// Growth indicator\nconst growthScore = avgViews / subs;\n\nreturn [{\n  json: {\n    artist: $json.items[0].snippet.title,\n    subscribers: subs,\n    views: views,\n    videos: videos,\n    avgViews: Math.round(avgViews),\n    growthScore: growthScore.toFixed(4)\n  }\n}];"
